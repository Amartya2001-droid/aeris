# Aeris Web — Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Privy (optional) ──────────────────────────────────────────────────────────
# Get your App ID from https://dashboard.privy.io
# Without this, the app runs in demo mode (simulated payments, no real wallet).
# NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# ── Solana RPC (optional) ─────────────────────────────────────────────────────
# Override the default devnet RPC if you have a private endpoint.
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
